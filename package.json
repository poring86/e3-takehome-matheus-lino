{
  "name": "e3-takehome-matheus-lino",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "architecture:test": "depcruise --config .dependency-cruiser.cjs src",
    "architecture:test:strict": "npm run architecture:test && npm run lint",
    "test": "vitest run",
    "test:notes:integration": "sh -c 'set -a; [ -f .env ] && . ./.env; [ -f .env.test ] && . ./.env.test; set +a; vitest run tests/api/notes.integration.test.ts'",
    "test:notes:integration:docker": "sh -c 'set -a; [ -f .env ] && . ./.env; [ -f .env.test ] && . ./.env.test; set +a; TEST_APP_BASE_URL=${TEST_APP_BASE_URL:-http://127.0.0.1:3000} vitest run tests/api/notes.integration.test.ts'",
    "test:notes:docker:full": "sh -c 'DOCKER_API_VERSION=${DOCKER_API_VERSION:-1.52} docker compose down --remove-orphans && DOCKER_API_VERSION=${DOCKER_API_VERSION:-1.52} docker compose up -d app && DOCKER_API_VERSION=${DOCKER_API_VERSION:-1.52} docker compose exec app npm run test:notes:integration'",
    "test:env:docker": "sh -c 'set -a; [ -f .env ] && . ./.env; [ -f .env.test ] && . ./.env.test; set +a; vitest run --hookTimeout=30000 --testTimeout=30000'",
    "test:docker:full": "sh -c 'DOCKER_API_VERSION=${DOCKER_API_VERSION:-1.52} docker compose down --remove-orphans && DOCKER_API_VERSION=${DOCKER_API_VERSION:-1.52} docker compose up -d app && DOCKER_API_VERSION=${DOCKER_API_VERSION:-1.52} docker compose exec app npm run test:env:docker'",
    "test:env": "sh -c 'set -a; [ -f .env ] && . ./.env; [ -f .env.test ] && . ./.env.test; set +a; vitest run'",
    "test:env:strict": "sh scripts/check-test-env.sh && npm run test:env",
    "smoke:notes": "sh scripts/smoke-notes.sh",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx scripts/seed.ts",
    "db:reset:seed": "tsx scripts/clean-and-seed.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "@tanstack/react-query": "^5.99.1",
    "@tiptap/extension-highlight": "^3.22.3",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@types/diff": "^7.0.2",
    "@types/pg": "^8.20.0",
    "ai": "^6.0.168",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "diff": "^9.0.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "openai": "^6.34.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "supertest": "^7.2.2",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^16.3.2",
    "@types/cypress": "^0.1.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.5.0",
    "cypress": "^15.14.0",
    "dependency-cruiser": "^17.3.10",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  }
}
